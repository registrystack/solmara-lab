{
	auto_https off
	admin off
}

# Single public ingress for the holder wallet.
#
# Coolify/Traefik terminates TLS for wallet.solmara.registrystack.org and forwards
# to this Caddy on :7101. Caddy serves the web wallet frontend and proxies
# /wallet-api/* to the wallet-api backend on the SAME origin. walt's web wallet
# calls the API at a relative /wallet-api path on its own origin, so this
# same-origin routing must be preserved (it is what walt's stock Caddyfile does;
# only the demo-wallet site block is kept here, the issuer/verifier/portal
# blocks are dropped because the Notary is the issuer in this lab).
:7101 {
	reverse_proxy http://waltid-demo-wallet:7101 # frontend
	reverse_proxy /wallet-api/* http://wallet-api:7001 # backend
}
