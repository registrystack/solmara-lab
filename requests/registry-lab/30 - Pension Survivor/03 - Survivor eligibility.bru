meta {
  name: 03 - Read SIPF survivor predicate
  type: http
  seq: 3
}

post {
  url: {{sipf_notary_url}}/v1/evaluations
  body: json
  auth: none
}

headers {
  x-api-key: {{SIPF_PENSION_CLIENT_TOKEN}}
  Data-Purpose: {{survivor_benefit_purpose}}
  Accept: application/vnd.registry-notary.claim-result+json
}

body:json {
  {
    "target": {
      "type": "Person",
      "identifiers": [
        {
          "scheme": "solmara_uin",
          "value": "2300109568"
        }
      ]
    },
    "claims": [
      "survivor-is-eligible"
    ],
    "disclosure": "predicate",
    "format": "application/vnd.registry-notary.claim-result+json"
  }
}
